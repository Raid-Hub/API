POSTGRES_PORT=5432
POSTGRES_USER=username
POSTGRES_PASSWORD=password

POSTGRES_WRITABLE_USER=username
POSTGRES_WRITABLE_PASSWORD=password

# API
PORT=8000
CLIENT_SECRET=123abc
ADMIN_CLIENT_SECRET=abc123
JWT_SECRET=secretkey

# When PROD=true, clients must send x-api-key matching an entry here (copy to api-keys.json).
API_KEYS_PATH=./api-keys.json

# RabbitMQ Management HTTP API (floodgates / ops); not used for AMQP publish.
RABBIT_API_USER=guest
RABBIT_API_PASSWORD=guest

# AMQP (same broker as Hermes): linked-role enqueue, player_crawl, etc.
# Defaults match RaidHub-Services docker-compose. For vanilla Rabbit (guest/guest), use RABBITMQ_USER=guest.
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=dev
RABBITMQ_PASSWORD=password
# RABBITMQ_VHOST=/

R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""
R2_BUCKET=""

# Sentry
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# Logging
LOG_LEVEL="info"

# Integration
DISCORD_PUBLIC_KEY=""
DISCORD_BOT_TOKEN=""
DISCORD_APPLICATION_ID=""

# Same Turso libsql URL as RaidHub-Website (NextAuth `account` table) so Discord invocation JWTs can resolve linked Bungie ids.
# RAIDHUB_ACCOUNT_TURSO_URL=

# Linked roles: Website BFF calls POST /internal/queue-discord-linked-role-sync with header x-raidhub-client-secret (same value as CLIENT_SECRET above); JSON body lists Destiny membership ids only. API publishes to Rabbit (must match Hermes).
# DISCORD_LINKED_ROLES_ENABLED=false
